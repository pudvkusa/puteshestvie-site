---
import Layout from '../../layouts/Layout.astro';
---

<Layout
  title="Блог ресторана Путешествие — о еде, кухне и Красногорске"
  description="Статьи о ресторанной культуре, русской кухне, гастроужинах и жизни ресторана Путешествие в Красногорске."
>
  <section style="background-color: #004f32; padding: 4rem 1rem;">
    <div class="max-w-7xl mx-auto">
      <h1 style="font-family: 'Lugatype', serif; text-transform: uppercase; letter-spacing: 0.05em; color: #b7b16b; font-size: clamp(2rem, 5vw, 3.5rem);">
        Статьи и материалы
      </h1>
    </div>
  </section>

  <section style="background-color: #F2EDE4; padding: 6rem 1rem; text-align: center;">
    <div class="max-w-2xl mx-auto">
      <p style="font-family: 'FalknerPro', serif; font-style: italic; color: #49544d; font-size: 1.2rem; line-height: 1.8; margin-bottom: 2rem;">
        Скоро здесь появятся статьи о русской кухне, гастрономической культуре и жизни ресторана.
      </p>
      <a
        href="/"
        style="background-color: #004f32; color: #b7b16b; font-family: 'Lugatype', serif; text-transform: uppercase; letter-spacing: 0.05em; padding: 0.75rem 2rem; font-size: 0.85rem; display: inline-block;"
        class="hover:opacity-85 transition-opacity"
      >
        На главную
      </a>
    </div>
  </section>
</Layout>
