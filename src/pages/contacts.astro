---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Контакты ресторана Путешествие — Красногорск, Балтийский бульвар 2с1"
  description="Адрес, телефон и часы работы ресторана Путешествие в Красногорске. Балтийский бульвар, 2с1. Чт–Вс 10:00–22:00."
>
  <section style="background-color: #004f32; padding: 4rem 1rem;">
    <div class="max-w-7xl mx-auto">
      <h1 style="font-family: 'Lugatype', serif; text-transform: uppercase; letter-spacing: 0.05em; color: #b7b16b; font-size: clamp(2rem, 5vw, 3.5rem);">
        Контакты
      </h1>
    </div>
  </section>

  <section style="background-color: #F2EDE4; padding: 5rem 1rem;">
    <div class="max-w-5xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-12 items-start">
      <!-- Info -->
      <div>
        <h2 style="font-family: 'Lugatype', serif; text-transform: uppercase; letter-spacing: 0.05em; color: #004f32; font-size: 1.5rem; margin-bottom: 1.5rem;">
          Как нас найти
        </h2>
        <div style="font-family: 'MuseoSansCyrl', sans-serif; color: #49544d; font-size: 1rem; line-height: 2.2;">
          <div style="margin-bottom: 1.5rem;">
            <p style="font-family: 'Lugatype', serif; text-transform: uppercase; letter-spacing: 0.05em; color: #004f32; font-size: 0.8rem; margin-bottom: 0.25rem;">Адрес</p>
            <p>Красногорск, Балтийский бульвар, 2с1</p>
          </div>
          <div style="margin-bottom: 1.5rem;">
            <p style="font-family: 'Lugatype', serif; text-transform: uppercase; letter-spacing: 0.05em; color: #004f32; font-size: 0.8rem; margin-bottom: 0.25rem;">Часы работы</p>
            <p>Четверг–Воскресенье: 10:00–22:00</p>
          </div>
          <div style="margin-bottom: 2rem;">
            <p style="font-family: 'Lugatype', serif; text-transform: uppercase; letter-spacing: 0.05em; color: #004f32; font-size: 0.8rem; margin-bottom: 0.25rem;">Бронирование</p>
            <a
              href="https://t.me/puteshestvie_rest_manager"
              target="_blank"
              rel="noopener noreferrer"
              style="color: #004f32; text-decoration: underline;"
              class="hover:opacity-75 transition-opacity"
            >
              @puteshestvie_rest_manager
            </a>
            <p style="margin-top: 0.5rem; font-size: 0.95rem;">
              <a
                href="tel:+79055551400"
                style="color: #004f32; text-decoration: underline;"
                class="hover:opacity-75 transition-opacity"
              >
                +7-905-555-14-00
              </a>
            </p>
          </div>
          <a
            href="https://t.me/puteshestvie_rest_manager"
            style="background-color: #004f32; color: #b7b16b; font-family: 'Lugatype', serif; text-transform: uppercase; letter-spacing: 0.05em; padding: 0.85rem 2rem; font-size: 0.85rem; display: inline-block;"
            class="hover:opacity-85 transition-opacity"
          >
            Забронировать стол
          </a>
        </div>
      </div>

      <!-- Yandex Map -->
      <div style="border-radius: 8px; overflow: hidden;">
        <iframe src="https://yandex.ru/map-widget/v1/?ll=37.227434%2C55.838708&z=16&pt=37.227434%2C55.838708%2Cpm2rdm" width="100%" height="400" frameborder="0" style="display: block;" allowfullscreen></iframe>
      </div>
    </div>
  </section>

  <!-- Privacy link -->
  <div style="background-color: #F2EDE4; padding: 0 1rem 3rem; text-align: center;">
    <a
      href="/privacy"
      style="font-family: 'MuseoSansCyrl', sans-serif; color: #49544d; font-size: 0.85rem; text-decoration: underline; opacity: 0.7;"
      class="hover:opacity-100 transition-opacity"
    >
      Политика конфиденциальности
    </a>
  </div>
</Layout>
