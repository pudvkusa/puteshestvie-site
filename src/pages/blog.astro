---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Блог ресторана Путешествие" description="Статьи о ресторанах Красногорска, русской кухне и атмосфере.">

  <section style="background-color: #004f32; padding: 5rem 1rem 4rem;">
    <div class="max-w-7xl mx-auto">
      <h1 style="font-family: 'Lugatype', serif; text-transform: uppercase; letter-spacing: 0.05em; color: #F2EDE4; font-size: clamp(1.8rem, 4vw, 2.8rem); margin-bottom: 1rem;">Блог</h1>
      <p style="font-family: 'MuseoSansCyrl', sans-serif; color: #F2EDE4; opacity: 0.85; font-size: 1rem;">Статьи о ресторанах, еде и атмосфере</p>
    </div>
  </section>

  <section style="background-color: #F2EDE4; padding: 4rem 1rem;">
    <div class="max-w-7xl mx-auto">
      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 2rem;">

        <a href="/blog/gde-otmetit-den-rozhdeniya-krasnogorsk" style="display: block; background: white; text-decoration: none; transition: opacity 0.2s;">
          <div style="background-color: #004f32; height: 200px; display: flex; align-items: center; justify-content: center; padding: 2rem;">
            <p style="font-family: 'FalknerPro', serif; font-style: italic; color: #b7b16b; font-size: 1.3rem; text-align: center; line-height: 1.4;">Где отметить день рождения в Красногорске</p>
          </div>
          <div style="padding: 1.5rem;">
            <p style="font-family: 'Lugatype', serif; text-transform: uppercase; letter-spacing: 0.06em; font-size: 0.7rem; color: #b7b16b; margin-bottom: 0.75rem;">Красногорск · Рестораны</p>
            <h2 style="font-family: 'MuseoSansCyrl', sans-serif; color: #004f32; font-size: 1.05rem; font-weight: 700; margin-bottom: 0.75rem; line-height: 1.4;">Где отметить день рождения в Красногорске: честный гид по местам</h2>
            <p style="font-family: 'MuseoSansCyrl', sans-serif; color: #49544d; font-size: 0.9rem; line-height: 1.6;">Разбираем форматы от банкетных залов до небольших ресторанов с атмосферой.</p>
            <p style="font-family: 'Lugatype', serif; color: #b7b16b; text-transform: uppercase; letter-spacing: 0.05em; font-size: 0.75rem; margin-top: 1rem;">Читать →</p>
          </div>
        </a>

        <a href="/blog/russkaya-kuhnya-podmoskovye" style="display: block; background: white; text-decoration: none; transition: opacity 0.2s;">
          <div style="background-color: #004f32; height: 200px; display: flex; align-items: center; justify-content: center; padding: 2rem;">
            <p style="font-family: 'FalknerPro', serif; font-style: italic; color: #b7b16b; font-size: 1.3rem; text-align: center; line-height: 1.4;">Русская кухня в Подмосковье</p>
          </div>
          <div style="padding: 1.5rem;">
            <p style="font-family: 'Lugatype', serif; text-transform: uppercase; letter-spacing: 0.06em; font-size: 0.7rem; color: #b7b16b; margin-bottom: 0.75rem;">Подмосковье · Кухня</p>
            <h2 style="font-family: 'MuseoSansCyrl', sans-serif; color: #004f32; font-size: 1.05rem; font-weight: 700; margin-bottom: 0.75rem; line-height: 1.4;">Русская кухня в Подмосковье: где попробовать настоящую</h2>
            <p style="font-family: 'MuseoSansCyrl', sans-serif; color: #49544d; font-size: 0.9rem; line-height: 1.6;">Авторская русская кухня редкий формат. Где её найти и как отличить от туристического.</p>
            <p style="font-family: 'Lugatype', serif; color: #b7b16b; text-transform: uppercase; letter-spacing: 0.05em; font-size: 0.75rem; margin-top: 1rem;">Читать →</p>
          </div>
        </a>

      </div>
    </div>
  </section>

</Layout>
