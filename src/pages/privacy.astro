---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Политика конфиденциальности — Ресторан Путешествие"
  description="Политика конфиденциальности ресторана Путешествие."
>
  <section style="background-color: #004f32; padding: 3rem 1rem;">
    <div class="max-w-7xl mx-auto">
      <h1 style="font-family: 'Lugatype', serif; text-transform: uppercase; letter-spacing: 0.05em; color: #b7b16b; font-size: 2rem;">
        Политика конфиденциальности
      </h1>
    </div>
  </section>
  <section style="background-color: #F2EDE4; padding: 4rem 1rem;">
    <div class="max-w-3xl mx-auto">
      <p style="font-family: 'MuseoSansCyrl', sans-serif; color: #49544d; font-size: 1rem; line-height: 1.8; margin-bottom: 1rem;">
        Документ находится в подготовке. Актуальная редакция политики конфиденциальности будет опубликована в ближайшее время.
      </p>
      <p style="font-family: 'MuseoSansCyrl', sans-serif; color: #49544d; font-size: 0.9rem; opacity: 0.7;">
        По вопросам обработки персональных данных обращайтесь через Telegram: @puteshestvie_rest_manager
      </p>
    </div>
  </section>
</Layout>
