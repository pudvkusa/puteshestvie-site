---
const navLinks = [
  { href: '/menu', label: 'Меню' },
  { href: '/banket', label: 'Банкеты' },
  { href: '/gastrouzhin', label: 'Гастроужины' },
  { href: '/blog', label: 'Блог' },
  { href: '/chef', label: 'Шеф' },
  { href: '/contacts', label: 'Контакты' },
];
---

<header style="background-color: #004f32;">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-20">
      <!-- Logo -->
      <a href="/" class="flex flex-col leading-tight">
        <span class="font-lugatype text-2xl md:text-3xl" style="color: #b7b16b; font-family: 'Lugatype', serif; text-transform: uppercase; letter-spacing: 0.05em;">
          Путешествие
        </span>
        <span style="color: #b7b16b; font-family: 'FalknerPro', serif; font-style: italic; font-size: 0.85rem;">
          со вкусом
        </span>
      </a>

      <!-- Desktop nav -->
      <nav class="hidden lg:flex items-center gap-6">
        {navLinks.map(link => (
          <a
            href={link.href}
            style="color: #b7b16b; font-family: 'Lugatype', serif; text-transform: uppercase; letter-spacing: 0.05em; font-size: 0.8rem;"
            class="hover:opacity-75 transition-opacity"
          >
            {link.label}
          </a>
        ))}
        <a
          href="https://t.me/puteshestvie_rest_manager"
          style="background-color: #b7b16b; color: #004f32; font-family: 'Lugatype', serif; text-transform: uppercase; letter-spacing: 0.05em; font-size: 0.75rem; padding: 0.5rem 1.25rem;"
          class="hover:opacity-85 transition-opacity whitespace-nowrap"
        >
          Забронировать
        </a>
      </nav>

      <!-- Mobile burger -->
      <button
        id="burger-btn"
        class="lg:hidden flex flex-col gap-1.5 p-2"
        aria-label="Открыть меню"
        aria-expanded="false"
      >
        <span class="burger-line block w-6 h-0.5 transition-all duration-300" style="background-color: #b7b16b;"></span>
        <span class="burger-line block w-6 h-0.5 transition-all duration-300" style="background-color: #b7b16b;"></span>
        <span class="burger-line block w-6 h-0.5 transition-all duration-300" style="background-color: #b7b16b;"></span>
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="lg:hidden hidden"
    style="background-color: #004f32;"
  >
    <nav class="flex flex-col px-6 pb-8 pt-4 gap-6">
      {navLinks.map(link => (
        <a
          href={link.href}
          style="color: #b7b16b; font-family: 'Lugatype', serif; text-transform: uppercase; letter-spacing: 0.05em; font-size: 1.1rem;"
          class="hover:opacity-75 transition-opacity"
        >
          {link.label}
        </a>
      ))}
      <a
        href="https://t.me/puteshestvie_rest_manager"
        style="background-color: #b7b16b; color: #004f32; font-family: 'Lugatype', serif; text-transform: uppercase; letter-spacing: 0.05em; font-size: 0.9rem; padding: 0.75rem 1.5rem; text-align: center;"
        class="hover:opacity-85 transition-opacity mt-2"
      >
        Забронировать стол
      </a>
    </nav>
  </div>
</header>

<script>
  const btn = document.getElementById('burger-btn');
  const menu = document.getElementById('mobile-menu');

  btn?.addEventListener('click', () => {
    const isOpen = menu?.classList.contains('hidden') === false;
    if (isOpen) {
      menu?.classList.add('hidden');
      btn.setAttribute('aria-expanded', 'false');
    } else {
      menu?.classList.remove('hidden');
      btn.setAttribute('aria-expanded', 'true');
    }
  });
</script>
